generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum UserStatus {
  ACTIVE
  INVITED
}

enum InventoryTransactionType {
  STOCK_IN
  STOCK_OUT
  TRANSFER
  ADJUSTMENT
  RESERVE
  RELEASE
  COMMIT_OUT
}

enum ApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum InboundStatus {
  DRAFT
  PENDING_RECEIPT
  RECEIVED
}

enum OutboundStatus {
  DRAFT
  PENDING_SHIPMENT
  SHIPPED
}

enum OcrDocumentKind {
  IMAGE
  PDF
}

enum OcrDocumentStatus {
  UPLOADED
  READY
  FAILED
  ARCHIVED
}

enum OcrJobType {
  DETECT
  EXTRACT
}

enum OcrJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum OcrFieldType {
  TEXT
  NUMBER
  DATE
  PHONE
  CODE
  CONTAINER_NO
}

enum OcrRiskLevel {
  NORMAL
  REVIEW
  HIGH_RISK
}

enum OcrValidationStatus {
  NOT_RUN
  PASSED
  FAILED
}

model User {
  id                   String   @id @default(cuid())
  name                 String?
  email                String   @unique
  passwordHash         String
  role                 UserRole @default(STAFF)
  status               UserStatus @default(ACTIVE)
  appointedBy          String?
  appointedAt          DateTime?
  permissionsUpdatedAt DateTime @default(now())
  lastLoginAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  transactions InventoryTransaction[] @relation("TransactionCreatedBy")
  inboundOrdersCreated InboundOrder[]  @relation("InboundCreatedBy")
  inboundOrdersApproved InboundOrder[] @relation("InboundApprovedBy")
  outboundOrdersCreated OutboundOrder[] @relation("OutboundCreatedBy")
  outboundOrdersApproved OutboundOrder[] @relation("OutboundApprovedBy")
  ocrDocumentsUploaded OcrDocument[]
  ocrTemplatesCreated  OcrTemplate[]
  ocrJobsRequested     OcrExtractionJob[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  description String?
  unit        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventories        Inventory[]
  transactions       InventoryTransaction[]
  inboundLineItems   InboundLineItem[]
  outboundLineItems  OutboundLineItem[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventories         Inventory[]
  transactions        InventoryTransaction[] @relation("TransactionWarehouse")
  sourceTransfers     InventoryTransaction[] @relation("SourceWarehouse")
  targetTransfers     InventoryTransaction[] @relation("TargetWarehouse")
  inboundOrders       InboundOrder[]
  outboundOrders      OutboundOrder[]
}

model Inventory {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  onHand      Int      @default(0)
  reserved    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId], map: "inventory_product_warehouse_unique")
  @@index([warehouseId], map: "inventory_warehouse_idx")
  @@index([productId], map: "inventory_product_idx")
}

model InventoryTransaction {
  id                String                   @id @default(cuid())
  type              InventoryTransactionType
  productId         String
  warehouseId       String
  sourceWarehouseId String?
  targetWarehouseId String?
  quantity          Int

  beforeOnHand      Int
  afterOnHand       Int
  beforeReserved    Int      @default(0)
  afterReserved     Int      @default(0)

  reference         String?
  note              String?
  createdById       String
  createdAt         DateTime                 @default(now())

  product           Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse         Warehouse  @relation("TransactionWarehouse", fields: [warehouseId], references: [id], onDelete: Cascade)
  sourceWarehouse   Warehouse? @relation("SourceWarehouse", fields: [sourceWarehouseId], references: [id], onDelete: NoAction)
  targetWarehouse   Warehouse? @relation("TargetWarehouse", fields: [targetWarehouseId], references: [id], onDelete: NoAction)
  createdBy         User       @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([productId, warehouseId])
  @@index([createdById])
  @@index([createdAt])
  @@index([type])
}

model InboundOrder {
  id                String         @id @default(cuid())
  inboundNo         String         @unique
  warehouseId       String
  supplierName      String
  referenceNo       String?
  plannedDate       DateTime
  status            InboundStatus  @default(DRAFT)
  approvalStatus    ApprovalStatus @default(PENDING_APPROVAL)
  approvalReason    String?
  notes             String?
  createdById       String
  approvedById      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  confirmedAt       DateTime?
  approvalUpdatedAt DateTime?
  appliedAt         DateTime?

  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy         User              @relation("InboundCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy        User?             @relation("InboundApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  lineItems         InboundLineItem[]

  @@index([warehouseId])
  @@index([createdById])
  @@index([approvalStatus])
  @@index([status])
}

model InboundLineItem {
  id             String       @id @default(cuid())
  inboundOrderId String
  productId      String
  quantity       Int
  notes          String?

  inboundOrder   InboundOrder @relation(fields: [inboundOrderId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([inboundOrderId])
  @@index([productId])
}

model OutboundOrder {
  id                String         @id @default(cuid())
  outboundNo        String         @unique
  warehouseId       String
  destination       String
  carrier           String?
  shipmentDate      DateTime
  status            OutboundStatus @default(DRAFT)
  approvalStatus    ApprovalStatus @default(PENDING_APPROVAL)
  approvalReason    String?
  notes             String?
  createdById       String
  approvedById      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  confirmedAt       DateTime?
  approvalUpdatedAt DateTime?
  appliedAt         DateTime?

  warehouse         Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy         User               @relation("OutboundCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  approvedBy        User?              @relation("OutboundApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  lineItems         OutboundLineItem[]

  @@index([warehouseId])
  @@index([createdById])
  @@index([approvalStatus])
  @@index([status])
}

model OutboundLineItem {
  id              String        @id @default(cuid())
  outboundOrderId String
  productId       String
  quantity        Int
  notes           String?

  outboundOrder   OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([outboundOrderId])
  @@index([productId])
}

model OcrDocument {
  id                String            @id @default(cuid())
  fileName          String
  originalMimeType  String
  kind              OcrDocumentKind
  storagePath       String
  pageCount         Int               @default(1)
  status            OcrDocumentStatus @default(UPLOADED)
  retentionExpiresAt DateTime?
  uploadedById      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  uploadedBy        User?             @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  pages             OcrDocumentPage[]
  jobs              OcrExtractionJob[]

  @@index([uploadedById])
  @@index([createdAt])
}

model OcrDocumentPage {
  id             String             @id @default(cuid())
  documentId     String
  pageNumber     Int
  sourceWidth    Int?
  sourceHeight   Int?
  qualityStatus  String?
  qualityDetails Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  document       OcrDocument        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  jobs           OcrExtractionJob[]
  results        OcrExtractionResult[]

  @@unique([documentId, pageNumber])
  @@index([documentId])
}

model OcrTemplate {
  id           String           @id @default(cuid())
  name         String
  description  String?
  anchorConfig Json?
  createdById  String?
  archivedAt   DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  createdBy    User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  fields       OcrTemplateField[]
  jobs         OcrExtractionJob[]

  @@index([createdById])
  @@index([archivedAt])
  @@index([createdAt])
}

model OcrTemplateField {
  id              String       @id @default(cuid())
  templateId      String
  fieldName       String
  outputColumn    String
  fieldType       OcrFieldType @default(TEXT)
  required        Boolean      @default(false)
  validationRule  String?
  riskRule        String?
  bboxNormalized  Json
  regionType      String?
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  template        OcrTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results         OcrExtractionResult[]

  @@index([templateId, sortOrder])
}

model OcrExtractionJob {
  id            String         @id @default(cuid())
  documentId    String
  documentPageId String
  templateId    String?
  jobType       OcrJobType
  status        OcrJobStatus   @default(PENDING)
  requestedById String?
  resultSummary Json?
  errorMessage  String?
  startedAt     DateTime?
  finishedAt    DateTime?
  durationMs    Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  document      OcrDocument    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentPage  OcrDocumentPage @relation(fields: [documentPageId], references: [id], onDelete: Cascade)
  template      OcrTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  requestedBy   User?          @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  results       OcrExtractionResult[]

  @@index([documentId])
  @@index([documentPageId])
  @@index([requestedById])
  @@index([status])
}

model OcrExtractionResult {
  id               String              @id @default(cuid())
  jobId            String
  documentPageId   String
  templateFieldId  String?
  fieldName        String
  outputColumn     String
  fieldType        OcrFieldType        @default(TEXT)
  ocrRawText       String?
  finalText        String?
  confidence       Float?
  riskLevel        OcrRiskLevel        @default(REVIEW)
  validationStatus OcrValidationStatus @default(NOT_RUN)
  validationMessage String?
  manuallyEdited   Boolean             @default(false)
  confirmedByUser  Boolean             @default(false)
  sourceBbox       Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  job              OcrExtractionJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  documentPage     OcrDocumentPage     @relation(fields: [documentPageId], references: [id], onDelete: Cascade)
  templateField    OcrTemplateField?   @relation(fields: [templateFieldId], references: [id], onDelete: SetNull)

  @@index([jobId])
  @@index([documentPageId])
  @@index([templateFieldId])
}
